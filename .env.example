# Gemini API 키 (필수, 답변 생성용) - https://aistudio.google.com/apikey 에서 무료 발급
GEMINI_API_KEY=

# Voyage AI API 키 (필수, 임베딩용) - https://dash.voyageai.com 에서 발급
VOYAGE_API_KEY=

# 답변 생성에 사용할 Gemini 모델 (무료 티어)
GEMINI_MODEL=gemini-2.5-flash

# 임베딩에 사용할 Voyage 모델
VOYAGE_EMBED_MODEL=voyage-4-lite

# 검색 시 가져올 청크 개수
TOP_K=5

# 색인 대상 문서 폴더
DOCS_DIR=docs

# Chroma 벡터 저장소 경로
CHROMA_DB_DIR=.chroma_db
